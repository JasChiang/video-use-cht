# video-use-cht uses LOCAL Breeze-ASR (WhisperX) — no transcription API key needed.
#
# HF_TOKEN is OPTIONAL: it is only used for speaker diarization (pyannote).
# Without it, transcription still works and every word is tagged speaker_0.
# To enable diarization for multi-speaker footage:
#   1. Create a token at https://huggingface.co/settings/tokens
#   2. Accept the gated terms for: pyannote/speaker-diarization-community-1
#      (pyannote.audio 4.x flagship pipeline; self-contained)
#   3. Paste the token below.
HF_TOKEN=

# Optional overrides:
# BREEZE_MODEL=breeze25      # breeze25 (中 + 英, default) | breeze26 / taigi (台 + 中)
# BREEZE_DEVICE=cpu          # CT2 has no Metal/MPS path on Apple Silicon
# BREEZE_COMPUTE_TYPE=int8   # int8 keeps CPU RAM/latency sane; try float32 for max accuracy
